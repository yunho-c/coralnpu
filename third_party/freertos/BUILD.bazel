load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

# Default configuration for FreeRTOS on CoralNPU
cc_library(
    name = "coralnpu_default_config",
    hdrs = [
        "config/FreeRTOSConfig.h",
        "config/freertos_risc_v_chip_specific_extensions.h",
    ],
    includes = ["config"],
)

# Label flag to allow overriding the FreeRTOS configuration
label_flag(
    name = "config",
    build_setting_default = ":coralnpu_default_config",
)
